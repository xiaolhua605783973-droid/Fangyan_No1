# 服务配置
APP_NAME=Elderly Dialect Speech Infrastructure
VERSION=1.0.0
DEBUG=False

# ASR 提供商（aliyun | tencent | whisper）
ASR_PROVIDER=aliyun

# 阿里云智能语音
ALIYUN_ACCESS_KEY=your_ram_access_key_id   # RAM AccessKey ID (LTAI5t...)
ALIYUN_ACCESS_SECRET=your_access_secret    # RAM AccessKey Secret
ALIYUN_NLS_APP_KEY=your_nls_app_key        # NLS 项目 AppKey (nls-portal 控制台)
ALIYUN_REGION=cn-shanghai
# 热词词表 ID（强烈推荐）：在阿里云 NLS 控制台 → 语音识别 → 热词管理 中创建
# 将护士/医生/救命/头晕/胸闷 等关键医疗词汇加入词表，可显著提升方言识别率
ALIYUN_VOCABULARY_ID=
# 自定义语言模型 ID（可选，如有对应方言模型）
ALIYUN_CUSTOMIZATION_ID=

# 腾讯云 ASR（备选）
TENCENT_SECRET_ID=your_secret_id_here
TENCENT_SECRET_KEY=your_secret_key_here

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=86400

# PostgreSQL
DATABASE_URL=postgresql://fangyan:password@localhost:5432/fangyan

# 成本控制
ENABLE_CACHE=True
ENABLE_DEDUP=True
