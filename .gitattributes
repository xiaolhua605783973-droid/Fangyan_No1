# 默认行为：文本文件使用 LF
* text=auto eol=lf

# Shell 脚本强制 LF（必须，否则在 Linux 执行会报 bad interpreter 错误）
*.sh text eol=lf

# Python 文件 LF
*.py text eol=lf

# YAML/JSON/Markdown LF
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Windows 专用批处理脚本保留 CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
